# Bounty Hunter Pro - Environment Configuration

# GitHub API Token (Required)
# Get yours from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Search Configuration
MIN_BOUNTY=20
MAX_TASKS_PER_RUN=50
DEFAULT_CURRENCY=USD

# Your Technical Skills (comma-separated)
MY_SKILLS=python,javascript,typescript,go,react,vue

# Agent Configuration
ENABLE_FORUM_DISCUSSION=true
FORUM_ROUNDS=3
MIN_HOURLY_RATE=10

# Output Configuration
OUTPUT_DIR=./reports
